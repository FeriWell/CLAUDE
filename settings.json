{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "MultiEdit(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "NotebookRead(*)",
      "NotebookEdit(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "TodoRead(*)",
      "TodoWrite(*)",
      "Agent(*)",
      "TaskCreate(*)",
      "TaskGet(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "TaskUpdate(*)",
      "mcp__claude-in-chrome__*",
      "mcp__claude_ai_Linear__*",
      "mcp__claude_ai_Slack__*",
      "mcp__claude_ai_Canva__*",
      "mcp__claude_ai_Figma__*",
      "mcp__claude_ai_Intercom__*",
      "mcp__claude_ai_Notion__*",
      "mcp__claude_ai_monday_com__*"
    ],
    "deny": [],
    "defaultMode": "bypassPermissions",
    "disableBypassPermissionsMode": "disable",
    "additionalDirectories": [
      "/home/fer",
      "/home/fer/iwell",
      "/etc",
      "/tmp",
      "/"
    ]
  },
  "model": "sonnet",
  "effortLevel": "high",
  "awaySummaryEnabled": false,
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.179",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "editorMode": "normal",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git pull --rebase --autostash -q origin master 2>/dev/null; git add -A && git diff --cached --quiet || git commit -m \"auto-sync: memory update\" && git push -q origin master 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Syncing memory to GitHub (FeriWell/CLAUDE)..."
          }
        ]
      }
    ]
  }
}